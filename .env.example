# Required: Google Gemini API key for AI chat responses
GOOGLE_API_KEY=

# Required: Qdrant Cloud vector database credentials
QDRANT_URL=
QDRANT_API_KEY=

# Optional: GitHub personal access token (for private repos and higher rate limits)
GITHUB_TOKEN=

# App URL (used for CORS and metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
